---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description: string;
	heroImage?: ImageMetadata;
}

const { title, description, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.hero-image {
				width: 100%;
				margin-bottom: 3rem;
				position: relative;
				overflow: hidden;
				border-radius: 0 0 24px 24px;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				max-height: 400px;
				width: 100%;
				object-fit: cover;
				border-radius: 0 0 24px 24px;
				box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
			}

			/* 히트박스 — 투명하지만 클릭 영역은 여유롭게 확보 */
			#cat-eye {
				position: absolute;
				width: 70px;
				height: 50px;
				transform: translate(-50%, -50%);
				cursor: crosshair;
				z-index: 10;
				border-radius: 50%;
			}

			/* 눈 글로우 - 크기를 줄이고 조금 더 선명한 원형/타원형으로 개선 */
			#eye-glow {
				position: absolute;
				width: 36px;
				height: 26px;
				transform: translate(-50%, -50%);
				border-radius: 50%;
				pointer-events: none;
				z-index: 9;
				opacity: 0;
				background: radial-gradient(ellipse at center, rgba(0, 255, 255, 0.9) 0%, rgba(0, 255, 255, 0) 70%);
				box-shadow: 0 0 12px 2px rgba(0, 255, 255, 0.8), inset 0 0 4px rgba(0, 255, 255, 0.5);
			}
			#eye-glow.flash {
				animation: glow-flash 1.2s ease-out forwards;
			}
			@keyframes glow-flash {
				0%   { opacity: 1; transform: translate(-50%, -50%) scale(1.2); }
				60%  { opacity: 0.8; transform: translate(-50%, -50%) scale(1); }
				100% { opacity: 0; transform: translate(-50%, -50%) scale(0.9); }
			}

			/* 빔 */
			#beam {
				position: absolute;
				height: 3px;
				width: 0;
				transform: translateY(-50%);
				background: linear-gradient(to right, cyan 0%, rgba(0,255,255,0.4) 70%, transparent 100%);
				box-shadow: 0 0 8px 2px rgba(0, 255, 255, 0.55);
				border-radius: 2px;
				pointer-events: none;
				opacity: 0;
				z-index: 8;
			}

			.about-wrapper {
				display: flex;
				flex-direction: column;
				align-items: center;
				text-align: center;
				gap: 1.5rem;
			}
			.about-wrapper h1 {
				font-size: 3rem;
				font-weight: 800;
				background: linear-gradient(to bottom, #fff, #a1a1aa);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				margin-bottom: 0.5rem;
			}
			.about-wrapper :global(p) {
				text-align: center;
				max-width: 60ch;
				margin: 0 auto;
				word-break: keep-all;
				line-height: 1.8;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			{heroImage && (
				<div class="hero-image" id="hero-container">
					<Image width={1020} height={400} src={heroImage} alt="" id="hero-img" />
					<div id="cat-eye" title="냥?"></div>
					<div id="eye-glow"></div>
					<div id="beam"></div>
				</div>
			)}
			<div class="about-wrapper">
				<h1>{title}</h1>
				<slot />
			</div>
		</main>
		<Footer />

		<script>
			const container = document.getElementById('hero-container') as HTMLElement | null;
			const eye      = document.getElementById('cat-eye')      as HTMLElement | null;
			const eyeGlow  = document.getElementById('eye-glow')     as HTMLElement | null;
			const beam     = document.getElementById('beam')         as HTMLElement | null;

			if (container && eye && eyeGlow && beam) {

			const NATURAL_W = 1024, NATURAL_H = 1024;
			// 찾아내신 최적의 좌표!
			const EYE_X = 600, EYE_Y = 504; 
			let originX = 0, originY = 0;

			function updatePosition() {
				const cW = container.offsetWidth;
				const cH = container.offsetHeight;
				const scale = Math.max(cW / NATURAL_W, cH / NATURAL_H);
				originX = EYE_X * scale + (cW - NATURAL_W * scale) / 2;
				originY = EYE_Y * scale + (cH - NATURAL_H * scale) / 2;
				eye.style.left = eyeGlow.style.left = `${originX}px`;
				eye.style.top  = eyeGlow.style.top  = `${originY}px`;
			}

			// --- 좌표 도우미 (개발자 도구 콘솔 확인용) ---
			// 이미지를 클릭하면 1024x1024 기준 원본 좌표가 콘솔에 찍힙니다!
			document.getElementById('hero-img')?.addEventListener('click', (e) => {
				const rect = container.getBoundingClientRect();
				const cW = container.offsetWidth;
				const cH = container.offsetHeight;
				const scale = Math.max(cW / NATURAL_W, cH / NATURAL_H);
				const clickX = e.clientX - rect.left;
				const clickY = e.clientY - rect.top;
				
				const natX = (clickX - (cW - NATURAL_W * scale) / 2) / scale;
				const natY = (clickY - (cH - NATURAL_H * scale) / 2) / scale;
				console.log(`[Eyepoint Helper] EYE_X: ${Math.round(natX)}, EYE_Y: ${Math.round(natY)}`);
			});
			// ---------------------------------------------
			let firing = false;
			function fire() {
				if (firing) return;
				firing = true;

				const maxWidth = container.offsetWidth - originX + 20;

				// 빔 초기화
				beam.style.transition = 'none';
				beam.style.left    = `${originX}px`;
				beam.style.top     = `${originY}px`;
				beam.style.width   = '0px';
				beam.style.opacity = '1';
				void beam.offsetWidth;

				// 글로우
				eyeGlow.classList.remove('flash');
				void eyeGlow.offsetWidth;
				eyeGlow.classList.add('flash');

				// 빔 성장
				beam.style.transition = 'width 0.5s cubic-bezier(0.1, 0.8, 0.3, 1)';
				beam.style.width = `${maxWidth}px`;

				// 페이드아웃
				setTimeout(() => {
					beam.style.transition = 'opacity 0.35s ease-out';
					beam.style.opacity = '0';
					setTimeout(() => {
						beam.style.transition = 'none';
						beam.style.width = '0px';
						firing = false;
					}, 380);
				}, 520);
			}

			updatePosition();
			window.addEventListener('resize', updatePosition);
			eye.addEventListener('click', fire);

			} // end if
		</script>
	</body>
</html>
