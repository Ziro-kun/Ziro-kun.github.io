---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description: string;
	heroImage?: ImageMetadata;
}

const { title, description, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.hero-image {
				width: 100%;
				margin-bottom: 3rem;
				position: relative;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				max-height: 400px;
				width: 100%;
				object-fit: cover;
				border-radius: 0 0 24px 24px;
				box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
			}
			.easter-egg-eye {
				position: absolute;
				top: 52%; /* Adjust roughly based on generated image */
				left: 45%;
				width: 60px;
				height: 60px;
				border-radius: 50%;
				transform: translate(-50%, -50%);
				cursor: pointer;
				z-index: 10;
				transition: all 0.3s ease;
				/* Invisible by default */
			}
			.easter-egg-eye.active {
				/* Odd-eye effect (e.g. Cyan blue) */
				background: radial-gradient(circle, rgba(0, 255, 255, 0.6) 0%, rgba(0, 255, 255, 0) 70%);
				mix-blend-mode: color-dodge;
				box-shadow: 0 0 15px rgba(0, 255, 255, 0.8), inset 0 0 10px rgba(0, 255, 255, 0.5);
			}
			.about-wrapper {
				display: flex;
				flex-direction: column;
				align-items: center;
				text-align: center;
				gap: 1.5rem;
			}
			.about-wrapper h1 {
				font-size: 3rem;
				font-weight: 800;
				background: linear-gradient(to bottom, #fff, #a1a1aa);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				margin-bottom: 0.5rem;
			}
			.about-wrapper :global(p) {
				text-align: center;
				max-width: 60ch;
				margin: 0 auto;
				word-break: keep-all;
				line-height: 1.8;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			{heroImage && (
				<div class="hero-image" id="hero-container">
					<Image width={1020} height={400} src={heroImage} alt="Hero Image" id="hero-img" />
					<div id="cat-eye" class="easter-egg-eye" title="냥?"></div>
				</div>
			)}
			<div class="about-wrapper">
				<h1>{title}</h1>
				<slot />
			</div>
		</main>
		<Footer />

		<script>
			// 고양이 오드아이 이스터에그 로직 (Astro에서는 스크립트가 모듈로 실행되므로 바로 실행)
			const eye = document.getElementById('cat-eye');
			if (eye) {
				eye.addEventListener('click', () => {
					eye.classList.toggle('active');
				});
			}
		</script>
	</body>
</html>
