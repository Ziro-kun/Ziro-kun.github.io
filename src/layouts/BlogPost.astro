---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Comments from '../components/Comments.astro';
import LikeButton from '../components/LikeButton.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	headings: { depth: number; slug: string; text: string }[];
	readingTime?: number;
	prevPost: CollectionEntry<'blog'> | null;
	nextPost: CollectionEntry<'blog'> | null;
	relatedPosts: CollectionEntry<'blog'>[];
};

const {
	title, description, pubDate, updatedDate, heroImage,
	tags, category, thumbnail,
	headings,
	prevPost, nextPost, relatedPosts,
} = Astro.props;

const CATEGORY_LABELS: Record<string, string> = {
	explore: 'Explore',
	'data-ml': 'Data & ML',
	growth: 'Growth',
	daily: 'Daily',
};

const tocHeadings = headings.filter((h) => h.depth === 1 || h.depth === 2);
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			/* 진행 바 */
			#progress-bar {
				position: fixed;
				top: 0;
				left: 0;
				height: 3px;
				width: 0%;
				background: var(--accent);
				z-index: 9999;
				transition: width 0.1s linear;
			}

			/* 히어로 이미지 */
			.hero-image {
				width: 100%;
				margin-bottom: 2rem;
			}
			.hero-image img {
				display: block;
				width: 100%;
				max-height: 500px;
				object-fit: cover;
				border-radius: 0 0 20px 20px;
				box-shadow: 0 20px 50px rgba(0,0,0,0.5);
			}

			/* 레이아웃: 본문 + TOC */
			.post-layout {
				display: grid;
				grid-template-columns: 1fr 240px;
				gap: 3rem;
				align-items: start;
			}

			/* 본문 영역 */
			.prose {
				min-width: 0;
				color: rgb(var(--white));
			}

			/* 포스트 헤더 */
			.post-header {
				margin-bottom: 2.5rem;
			}
			.post-meta {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				flex-wrap: wrap;
				margin-bottom: 1rem;
			}
			.category-badge {
				display: inline-block;
				padding: 0.2rem 0.75rem;
				background: rgba(212,255,0,0.1);
				color: var(--accent);
				border: 1px solid rgba(212,255,0,0.3);
				border-radius: 999px;
				font-size: 0.8rem;
				font-weight: 600;
				text-decoration: none;
			}
			.meta-divider {
				color: rgb(var(--gray));
				font-size: 0.8rem;
			}
			.meta-item {
				font-size: 0.85rem;
				color: rgb(var(--gray));
			}
			.post-header h1 {
				font-size: 2.8rem;
				font-weight: 800;
				line-height: 1.25;
				background: linear-gradient(to bottom, #fff, #a1a1aa);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				margin: 0 0 1rem 0;
			}
			.post-description {
				font-size: 1.1rem;
				color: rgb(var(--gray-dark));
				line-height: 1.6;
				margin: 0;
			}
			.divider {
				border: none;
				border-top: 1px solid #27272a;
				margin: 2rem 0;
			}

			/* 태그 */
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin-top: 2.5rem;
				padding-top: 2rem;
				border-top: 1px solid #27272a;
			}
			.tag {
				padding: 0.25rem 0.75rem;
				background: #27272a;
				color: rgb(var(--gray-dark));
				border-radius: 999px;
				font-size: 0.8rem;
				text-decoration: none;
				transition: all 0.2s;
			}
			.tag:hover {
				background: rgba(212,255,0,0.1);
				color: var(--accent);
			}

			/* 이전/다음 네비게이션 */
			.post-nav {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1rem;
				margin-top: 3rem;
				padding-top: 2rem;
				border-top: 1px solid #27272a;
			}
			.post-nav a {
				display: flex;
				flex-direction: column;
				gap: 0.3rem;
				padding: 1rem;
				background: #18181b;
				border: 1px solid #27272a;
				border-radius: 12px;
				text-decoration: none;
				transition: all 0.2s;
			}
			.post-nav a:hover {
				border-color: var(--accent);
			}
			.post-nav .nav-label {
				font-size: 0.75rem;
				color: rgb(var(--gray));
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			.post-nav .nav-title {
				font-size: 0.95rem;
				color: white;
				font-weight: 500;
				overflow: hidden;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
			}
			.post-nav .next-post { text-align: right; }

			/* 연관 포스트 */
			.related {
				margin-top: 3rem;
				padding-top: 2rem;
				border-top: 1px solid #27272a;
			}
			.related h2 {
				font-size: 1.1rem;
				font-weight: 700;
				color: rgb(var(--gray-dark));
				margin: 0 0 1rem 0;
			}
			.related-list {
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.related-list a {
				display: flex;
				justify-content: space-between;
				align-items: center;
				gap: 1rem;
				padding: 0.75rem 1rem;
				background: #18181b;
				border: 1px solid #27272a;
				border-radius: 10px;
				text-decoration: none;
				transition: all 0.2s;
			}
			.related-list a:hover { border-color: var(--accent); }
			.related-list .r-title {
				font-size: 0.9rem;
				color: white;
				overflow: hidden;
				display: -webkit-box;
				-webkit-line-clamp: 1;
				-webkit-box-orient: vertical;
			}
			.related-list .r-date {
				font-size: 0.8rem;
				color: rgb(var(--gray));
				white-space: nowrap;
			}

			/* TOC */
			.toc-panel {
				position: sticky;
				top: 5rem;
				max-height: calc(100vh - 7rem);
				overflow-y: auto;
				padding: 1.25rem;
				background: #18181b;
				border: 1px solid #27272a;
				border-radius: 12px;
				font-size: 0.85rem;
			}
			.toc-panel::-webkit-scrollbar { width: 4px; }
			.toc-panel::-webkit-scrollbar-thumb { background: #3f3f46; border-radius: 4px; }
			.toc-panel h3 {
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: rgb(var(--gray));
				margin: 0 0 0.75rem 0;
			}
			.toc-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 0.25rem;
			}
			.toc-list a {
				display: block;
				padding: 0.25rem 0.5rem;
				color: rgb(var(--gray-dark));
				text-decoration: none;
				border-radius: 6px;
				transition: all 0.15s;
				line-height: 1.4;
			}
			.toc-list a:hover,
			.toc-list a.active { color: var(--accent); background: rgba(212,255,0,0.06); }
			.toc-list .depth-3 { padding-left: 1rem; font-size: 0.8rem; }

			/* 스크롤 버튼 */
			.scroll-buttons {
				position: fixed;
				bottom: 2rem;
				right: 2rem;
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
				z-index: 100;
			}
			.scroll-btn {
				width: 40px;
				height: 40px;
				background: #27272a;
				border: 1px solid #3f3f46;
				border-radius: 10px;
				cursor: pointer;
				display: flex;
				align-items: center;
				justify-content: center;
				color: rgb(var(--gray-dark));
				font-size: 1rem;
				transition: all 0.2s;
			}
			.scroll-btn:hover {
				background: rgba(212,255,0,0.1);
				border-color: var(--accent);
				color: var(--accent);
			}

			@media (max-width: 900px) {
				.post-layout { grid-template-columns: 1fr; }
				.toc-panel { display: none; }
				.post-header h1 { font-size: 2rem; }
				.post-nav { grid-template-columns: 1fr; }
			}
		</style>
	</head>
	<body>
		<div id="progress-bar"></div>
		<Header />

		{(heroImage || thumbnail) && (
			<div class="hero-image">
				{heroImage
					? <Image width={1200} height={500} src={heroImage} alt="" />
					: <img src={thumbnail} alt="" loading="eager" />
				}
			</div>
		)}

		<main>
			<div class="post-layout">
				<!-- 본문 -->
				<article class="prose">
					<header class="post-header">
						<div class="post-meta">
							{category && (
								<a class="category-badge" href={`/blog/category/${category}`}>
									{CATEGORY_LABELS[category] ?? category}
								</a>
							)}
							<span class="meta-divider">·</span>
							<span class="meta-item"><FormattedDate date={pubDate} /></span>
							</div>
						<h1>{title}</h1>
						{description && <p class="post-description">{description}</p>}
					</header>

					<hr class="divider" />
					<slot />

					{tags && tags.length > 0 && (
						<div class="tags">
							{tags.map((tag) => (
								<span class="tag">#{tag}</span>
							))}
						</div>
					)}

					{(prevPost || nextPost) && (
						<nav class="post-nav">
							{prevPost
								? (
									<a href={`/blog/${prevPost.id}/`}>
										<span class="nav-label">← 이전 글</span>
										<span class="nav-title">{prevPost.data.title}</span>
									</a>
								)
								: <div />
							}
							{nextPost && (
								<a class="next-post" href={`/blog/${nextPost.id}/`}>
									<span class="nav-label">다음 글 →</span>
									<span class="nav-title">{nextPost.data.title}</span>
								</a>
							)}
						</nav>
					)}

					{relatedPosts.length > 0 && (
						<div class="related">
							<h2>연관 포스트</h2>
							<ul class="related-list">
								{relatedPosts.map((p) => (
									<li>
										<a href={`/blog/${p.id}/`}>
											<span class="r-title">{p.data.title}</span>
											<span class="r-date"><FormattedDate date={p.data.pubDate} /></span>
										</a>
									</li>
								))}
							</ul>
						</div>
					)}

					<LikeButton />

					<Comments />
				</article>

				<!-- TOC -->
				{tocHeadings.length > 0 && (
					<aside class="toc-panel">
						<h3>목차</h3>
						<ul class="toc-list">
							{tocHeadings.map((h) => (
								<li>
									<a href={`#${h.slug}`} class={h.depth === 3 ? 'depth-3' : ''}>
										{h.text}
									</a>
								</li>
							))}
						</ul>
					</aside>
				)}
			</div>
		</main>

		<!-- 스크롤 버튼 -->
		<div class="scroll-buttons">
			<button class="scroll-btn" id="scroll-top" title="맨 위로">↑</button>
			<button class="scroll-btn" id="scroll-bottom" title="맨 아래로">↓</button>
		</div>

		<Footer />

		<script>
			// 읽기 진행 바
			const bar = document.getElementById('progress-bar') as HTMLDivElement;
			window.addEventListener('scroll', () => {
				const scrolled = window.scrollY;
				const total = document.body.scrollHeight - window.innerHeight;
				bar.style.width = total > 0 ? `${(scrolled / total) * 100}%` : '0%';
			});

			// 스크롤 버튼
			document.getElementById('scroll-top')?.addEventListener('click', () =>
				window.scrollTo({ top: 0, behavior: 'smooth' })
			);
			document.getElementById('scroll-bottom')?.addEventListener('click', () =>
				window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' })
			);

			// TOC 활성화
			const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-list a');
			const headingEls = document.querySelectorAll<HTMLElement>('h2[id], h3[id]');
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							tocLinks.forEach((a) => a.classList.remove('active'));
							const active = document.querySelector(`.toc-list a[href="#${entry.target.id}"]`);
							active?.classList.add('active');
						}
					});
				},
				{ rootMargin: '-20% 0% -70% 0%' }
			);
			headingEls.forEach((el) => observer.observe(el));
		</script>
	</body>
</html>
