---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';

export async function getStaticPaths() {
	const categories = ['explore', 'data-ml', 'growth', 'daily'];
	return categories.map((category) => ({ params: { category } }));
}

const CATEGORY_LABELS: Record<string, string> = {
	explore: 'Explore',
	'data-ml': 'Data & ML',
	growth: 'Growth',
	daily: 'Daily',
};

const { category } = Astro.params;
const label = CATEGORY_LABELS[category] ?? category;

const allPosts = await getCollection('blog');
const posts = allPosts
	.filter((post) => post.data.category === category)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={label} description={`${label} 카테고리 포스트 목록`} />
		<style>
			.category-header {
				padding: 3rem 0 2rem;
				text-align: center;
			}
			.category-header h1 {
				font-size: 2.5rem;
				font-weight: 800;
				background: linear-gradient(to right, var(--accent), #fff);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				margin-bottom: 0.5rem;
			}
			.category-header p {
				color: rgb(var(--gray));
			}
			.blog-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
				gap: 2rem;
				list-style-type: none;
				margin: 2rem 0 4rem;
				padding: 0;
				max-width: 960px;
				margin-inline: auto;
			}
			.blog-card {
				background: #18181b;
				border: 1px solid #27272a;
				border-radius: 16px;
				overflow: hidden;
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
			}
			.blog-card:hover {
				transform: translateY(-6px);
				border-color: var(--accent);
				box-shadow: 0 0 30px rgba(212, 255, 0, 0.1);
			}
			.blog-card a {
				text-decoration: none;
				color: inherit;
				display: flex;
				flex-direction: column;
				height: 100%;
			}
			.blog-card-content {
				padding: 1.5rem;
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
			}
			.date {
				font-size: 0.875rem;
				color: rgb(var(--gray));
			}
			.blog-card-content h2 {
				font-size: 1.25rem;
				margin: 0;
				color: white;
				transition: color 0.2s ease;
			}
			.blog-card:hover h2 {
				color: var(--accent);
			}
			.blog-card-content p {
				font-size: 0.95rem;
				color: rgb(var(--gray-dark));
				margin: 0;
				overflow: hidden;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
			}
			.empty {
				text-align: center;
				color: rgb(var(--gray));
				padding: 4rem 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="category-header">
				<h1>{label}</h1>
				<p>{posts.length}개의 포스트</p>
			</div>
			{posts.length === 0 ? (
				<p class="empty">아직 포스트가 없습니다.</p>
			) : (
				<ul class="blog-grid">
					{posts.map((post) => (
						<li class="blog-card">
							<a href={'/blog/' + post.id + '/'}>
									{post.data.heroImage ? (
										<Image src={post.data.heroImage} alt="" width="720" height="360" loading="lazy" style="width:100%;height:180px;object-fit:cover;" />
									) : post.data.thumbnail ? (
										<img src={post.data.thumbnail} alt="" width="720" height="360" loading="lazy" style="width:100%;height:180px;object-fit:cover;" />
									) : null}
									<p>{post.data.description}</p>
								</div>
							</a>
						</li>
					))}
				</ul>
			)}
		</main>
		<Footer />
	</body>
</html>
