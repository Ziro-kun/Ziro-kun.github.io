---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = (await getCollection('blog')).sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
	);
	return posts.map((post, index) => ({
		params: { slug: post.id },
		props: {
			post,
			prevPost: posts[index + 1] ?? null,
			nextPost: posts[index - 1] ?? null,
			relatedPosts: posts
				.filter((p) => p.id !== post.id && p.data.category === post.data.category)
				.slice(0, 3),
		},
	}));
}

type Props = {
	post: CollectionEntry<'blog'>;
	prevPost: CollectionEntry<'blog'> | null;
	nextPost: CollectionEntry<'blog'> | null;
	relatedPosts: CollectionEntry<'blog'>[];
};

const { post, prevPost, nextPost, relatedPosts } = Astro.props;
const { Content, headings } = await render(post);

// 읽기 시간 계산 (한국어 기준 분당 약 500자)
const wordCount = post.body?.length ?? 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 500));
---

<BlogPost
	{...post.data}
	headings={headings}
	readingTime={readingTime}
	prevPost={prevPost}
	nextPost={nextPost}
	relatedPosts={relatedPosts}
>
	<Content />
</BlogPost>
