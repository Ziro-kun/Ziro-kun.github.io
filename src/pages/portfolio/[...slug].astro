---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import PortfolioLayout from '../../layouts/PortfolioLayout.astro';

export async function getStaticPaths() {
	const portfolios = await getCollection('portfolio');
	return portfolios
		.filter((item) => item.id.includes('/'))
		.map((item) => ({
			params: { slug: item.id },
			props: { item },
		}));
}

interface Props {
	item: CollectionEntry<'portfolio'>;
}

const { item } = Astro.props;
const { Content } = await render(item);

const categoryPath = item.id.split('/')[0];
const categoryLabel: Record<string, string> = {
	intel: 'Intel Projects',
	mini: 'Mini Projects',
	career: 'Career Projects',
};
---

<PortfolioLayout title={`${item.data.title} | Portfolio`} description={item.data.description}>
	<nav class="breadcrumb">
		<a href="/portfolio">Portfolio</a> /
		<a href={`/portfolio/${categoryPath}`}>{categoryLabel[categoryPath] ?? categoryPath}</a> /
		{item.data.title}
	</nav>

	<div class="project-header">
		<h1>{item.data.title}</h1>
		<div class="meta-row">
			{item.data.type && <span class="badge">{item.data.type}</span>}
			{item.data.teamSize && <span class="meta-item">👥 {item.data.teamSize}명</span>}
		</div>
		{item.data.role && <p class="role-text">역할: {item.data.role}</p>}
		<div class="link-row">
			{item.data.github && (
				<a href={item.data.github} target="_blank" rel="noopener noreferrer" class="link-btn github">
					💻 GitHub
				</a>
			)}
			{item.data.link && (
				<a href={item.data.link} target="_blank" rel="noopener noreferrer" class="link-btn">
					🔗 프로젝트 보기
				</a>
			)}
		</div>
	</div>

	<hr />

	<div class="project-content">
		<Content />
	</div>
</PortfolioLayout>

<style>
	.breadcrumb {
		font-size: 0.875rem;
		color: var(--gray);
		margin-bottom: 2rem;
	}
	.breadcrumb a {
		color: var(--accent);
		text-decoration: none;
	}
	.breadcrumb a:hover {
		text-decoration: underline;
	}

	.project-header {
		margin-bottom: 1.5rem;
	}

	.project-header h1 {
		font-size: 1.8rem;
		margin: 0 0 0.75rem;
	}

	.meta-row {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-wrap: wrap;
		margin-bottom: 0.5rem;
	}

	.badge {
		display: inline-block;
		background: var(--accent);
		color: #000;
		padding: 0.2rem 0.65rem;
		border-radius: 0.25rem;
		font-size: 0.8rem;
		font-weight: 700;
	}

	.meta-item {
		font-size: 0.9rem;
		color: rgb(var(--gray));
	}

	.role-text {
		font-size: 0.9rem;
		color: rgb(var(--gray));
		margin: 0.5rem 0 0;
	}

	.link-row {
		display: flex;
		gap: 0.75rem;
		margin-top: 1rem;
		flex-wrap: wrap;
	}

	.link-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.5rem 1.1rem;
		background: rgba(255,255,255,0.08);
		border: 1px solid rgba(255,255,255,0.15);
		color: white;
		text-decoration: none;
		border-radius: 0.375rem;
		font-size: 0.875rem;
		font-weight: 500;
		transition: background 0.2s;
	}
	.link-btn:hover {
		background: rgba(255,255,255,0.14);
	}
	.link-btn.github {
		border-color: rgba(255,255,255,0.2);
	}

	.project-content {
		line-height: 1.8;
	}
</style>
