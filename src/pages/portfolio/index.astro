---
import { getCollection, render } from 'astro:content';
import PortfolioLayout from '../../layouts/PortfolioLayout.astro';

const portfolios = await getCollection('portfolio');
const introEntry = portfolios.find((item) => item.id === 'index');
if (!introEntry) throw new Error('portfolio/index.md not found');

const { Content } = await render(introEntry);
---

<PortfolioLayout title="Portfolio | Zi-log" description={introEntry.data.description}>
	<Content />
</PortfolioLayout>
