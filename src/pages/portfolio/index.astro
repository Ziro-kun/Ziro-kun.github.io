---
import { getCollection, render } from 'astro:content';
import PortfolioLayout from '../../layouts/PortfolioLayout.astro';

const portfolios = await getCollection('portfolio');
const introEntry = portfolios.find((item) => item.id === 'index');
if (!introEntry) throw new Error('portfolio/index.md not found');

const { Content } = await render(introEntry);
---

<PortfolioLayout title="Portfolio | Zi-log" description={introEntry.data.description}>
	<div class="page-header">
		<h1>Ziro's Portfolio</h1>
		<p class="tagline">
			<strong>"문제 재정의와 구조적 사고를 통해 더 나은 솔루션을 설계합니다."</strong><br />
			과거의 기획 경험과 현재의 기술적 역량을 결합하여 실질적인 변화를 만드는 엔지니어가 되고자 합니다.
		</p>
	</div>
	<hr />
	<Content />
</PortfolioLayout>

<style>
	.page-header {
		margin-bottom: 0;
	}
	.page-header h1 {
		font-size: 2rem;
		font-weight: 800;
		margin: 0 0 0.75rem;
		color: var(--accent);
	}
	.tagline {
		font-size: 0.95rem;
		line-height: 1.8;
		color: rgb(var(--gray));
		margin: 0;
	}
</style>
