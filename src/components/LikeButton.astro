---
// Supabase 환경변수는 .env에서 주입됩니다
---

<div class="like-container">
  <button id="like-btn" class="like-btn" title="좋아요" aria-label="좋아요">
    <span class="heart-icon">♡</span>
    <span class="like-count" id="like-count">0</span>
  </button>
</div>

<script>
  const BASE = import.meta.env.PUBLIC_SUPABASE_URL;
  const KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  const postPath = window.location.pathname;

  const baseHeaders = {
    apikey: KEY,
    Authorization: `Bearer ${KEY}`,
    'Content-Type': 'application/json',
  };

  // 세션 ID 가져오기 (사용자 추적용)
  function getSessionId() {
    let sid = localStorage.getItem('session_id');
    if (!sid) {
      sid = `${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;
      localStorage.setItem('session_id', sid);
    }
    return sid;
  }

  // 좋아요 수 불러오기
  async function loadLikeCount() {
    try {
      const res = await fetch(
        `${BASE}/rest/v1/likes?post_path=eq.${encodeURIComponent(postPath)}&select=id`,
        { headers: baseHeaders }
      );
      const data = await res.json();
      const count = Array.isArray(data) ? data.length : 0;
      document.getElementById('like-count').textContent = count;
      return count;
    } catch (e) {
      console.error('Failed to load likes:', e);
      return 0;
    }
  }

  // 현재 사용자가 좋아요 했는지 확인
  async function isUserLiked() {
    try {
      const sessionId = getSessionId();
      const res = await fetch(
        `${BASE}/rest/v1/likes?post_path=eq.${encodeURIComponent(postPath)}&session_id=eq.${encodeURIComponent(sessionId)}&select=id`,
        { headers: baseHeaders }
      );
      const data = await res.json();
      return Array.isArray(data) && data.length > 0;
    } catch {
      return false;
    }
  }

  // 좋아요 추가/제거
  async function toggleLike() {
    const btn = document.getElementById('like-btn');
    const sessionId = getSessionId();

    try {
      const liked = await isUserLiked();

      if (liked) {
        // 좋아요 제거
        await fetch(
          `${BASE}/rest/v1/likes?post_path=eq.${encodeURIComponent(postPath)}&session_id=eq.${encodeURIComponent(sessionId)}`,
          {
            method: 'DELETE',
            headers: baseHeaders,
          }
        );
        btn.classList.remove('liked');
      } else {
        // 좋아요 추가
        await fetch(`${BASE}/rest/v1/likes`, {
          method: 'POST',
          headers: { ...baseHeaders, Prefer: 'return=minimal' },
          body: JSON.stringify({ post_path: postPath, session_id: sessionId }),
        });
        btn.classList.add('liked');
      }

      await loadLikeCount();
    } catch (e) {
      console.error('Failed to toggle like:', e);
    }
  }

  // 초기화
  async function init() {
    const btn = document.getElementById('like-btn');
    await loadLikeCount();

    // 사용자가 이미 좋아요 했는지 확인
    if (await isUserLiked()) {
      btn.classList.add('liked');
    }

    btn.addEventListener('click', toggleLike);
  }

  init();
</script>

<style>
  .like-container {
    margin: 2rem 0;
    display: flex;
    justify-content: center;
  }

  .like-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.2rem;
    background: rgba(212, 255, 0, 0.05);
    border: 1px solid rgba(212, 255, 0, 0.2);
    border-radius: 50px;
    color: rgb(var(--gray-dark));
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .like-btn:hover {
    background: rgba(212, 255, 0, 0.1);
    border-color: rgba(212, 255, 0, 0.4);
  }

  .like-btn.liked {
    background: rgba(212, 255, 0, 0.15);
    border-color: var(--accent);
    color: var(--accent);
  }

  .like-btn.liked .heart-icon {
    color: #ff6b6b;
    animation: pop 0.3s ease;
  }

  .heart-icon {
    font-size: 1.1em;
    transition: color 0.2s;
  }

  .like-count {
    font-size: 0.9em;
    min-width: 1.5em;
    text-align: right;
  }

  @keyframes pop {
    0% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.3);
    }
    100% {
      transform: scale(1);
    }
  }

  @media (max-width: 720px) {
    .like-btn {
      padding: 0.5rem 1rem;
      font-size: 0.95rem;
    }
  }
</style>
