---
// giscus.app에서 발급받은 값으로 교체하세요
// 설정 방법: https://giscus.app → repo 입력 후 생성된 script 태그에서 복사
const REPO = "Ziro-kun/Ziro-kun.github.io";
const REPO_ID = "R_kgDOMV056g";        // data-repo-id
const CATEGORY = "General";
const CATEGORY_ID = "DIC_kwDOMV056s4C_3_Z";    // data-category-id
---

<section class="giscus-wrap">
  <script
    is:inline
    src="https://giscus.app/client.js"
    data-repo={REPO}
    data-repo-id={REPO_ID}
    data-category={CATEGORY}
    data-category-id={CATEGORY_ID}
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="top"
    data-theme="dark_dimmed"
    data-lang="ko"
    crossorigin="anonymous"
    async
  ></script>
</section>

<style>
  .giscus-wrap {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid #27272a;
  }
</style>
